<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- PreviewView -->
    <io.github.thibaultbee.streampack.ui.views.PreviewView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 聊天列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="10dp"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:padding="16dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/cameraButtonsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.45" />

    <!-- 左下角後置鏡頭按鈕列（固定位置，不滾動） -->
    <LinearLayout
        android:id="@+id/cameraButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/cameraControls"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="5dp" />

    <!-- 網路訊號 Overlay -->
    <com.kongjjj.livestreamingcamera.ui.NetworkSignalOverlay
        android:id="@+id/networkSignalOverlay"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="0dp"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/batteryOverlay" />

    <!-- 電池 Overlay 頂部對齊 -->
    <com.kongjjj.livestreamingcamera.ui.BatteryOverlay
        android:id="@+id/batteryOverlay"
        android:layout_width="40dp"
        android:layout_height="77dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="0dp"
        app:layout_constraintEnd_toStartOf="@+id/topRightButtonContainer"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 右上角按鈕容器 -->
    <LinearLayout
        android:id="@+id/topRightButtonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="0dp"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" >


        <ImageButton
            android:id="@+id/menuButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_menu"
            android:contentDescription="@string/menu_button_desc"
            android:layout_marginBottom="4dp" />

        <!-- 變焦按鈕 -->
        <ImageButton
            android:id="@+id/zoomButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_zoom"
            android:contentDescription="變焦"
            android:layout_marginBottom="4dp" />

        <!-- 藍牙開關按鈕 -->
        <ImageButton
            android:id="@+id/bluetoothButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_bluetooth_off"
            android:contentDescription="藍牙麥克風開關"
            android:layout_marginBottom="4dp" />

        <!-- 聊天開關按鈕 -->
        <ImageButton
            android:id="@+id/chatButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_chat_on"
            android:contentDescription="@string/chat_switch_desc"
            android:layout_marginBottom="4dp" />


    </LinearLayout>

    <!-- 全黑覆蓋層 -->
    <View
        android:id="@+id/blackOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 左上角直播狀態文字 -->
    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="2dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="RTMP 離線"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:background="@android:color/transparent"
        android:elevation="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/audioLevelOverlay" />

    <!-- 音量條 -->
    <com.kongjjj.livestreamingcamera.ui.components.AudioLevelOverlay
        android:id="@+id/audioLevelOverlay"
        android:layout_width="120dp"
        android:layout_height="12dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="15dp"
        android:elevation="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 串流統計疊加層 -->
    <com.kongjjj.livestreamingcamera.ui.components.StreamStatsOverlay
        android:id="@+id/streamStatsOverlay"
        android:layout_width="90dp"
        android:layout_height="55dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="15dp"
        android:elevation="20dp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/audioLevelOverlay"
        app:layout_constraintTop_toTopOf="parent" />


    <!-- 右下角相機控制按鈕群 -->
    <LinearLayout
        android:id="@+id/cameraControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="5dp"
        android:elevation="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 觀看人數容器（置於直播按鈕左側） -->
        <LinearLayout
            android:id="@+id/viewerCountLayout"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="bottom"
            android:layout_marginEnd="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/viewerIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_person"
                android:contentDescription="@string/viewer_icon_desc"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/viewerCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/viewer_count_default"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 直播時長顯示 -->
        <TextView
            android:id="@+id/uptimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <!-- 直播按鈕 (新位置，統一大小為45dp) -->
        <ToggleButton
            android:id="@+id/liveButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/ic_live_button_selector"
            android:gravity="center"
            android:padding="0dp"
            android:textOff=""
            android:textOn=""
            android:contentDescription="@string/live_button_desc" />

        <!-- 靜音按鈕 -->
        <ImageButton
            android:id="@+id/muteButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/mute_desc"
            android:src="@drawable/ic_mute_off" />

        <!-- 閃光燈按鈕 -->
        <ImageButton
            android:id="@+id/flashButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/flash_desc"
            android:src="@drawable/ic_flash_auto" />

        <!-- 切換鏡頭按鈕 -->
        <ImageButton
            android:id="@+id/switchCameraButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_switch_camera"
            android:contentDescription="@string/switch_camera_desc" />

        <!-- 白平衡按鈕 -->
        <ImageButton
            android:id="@+id/whiteBalanceButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/white_balance_desc"
            android:src="@drawable/ic_white_balance" />

        <!-- 曝光補償按鈕 -->
        <ImageButton
            android:id="@+id/exposureButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/exposure_desc"
            android:src="@drawable/ic_exposure" />

        <!-- 對焦模式按鈕 -->
        <ImageButton
            android:id="@+id/focusButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/focus_desc"
            android:src="@drawable/ic_focus" />

        <!-- 黑色畫面按鈕 -->
        <ImageButton
            android:id="@+id/blackScreenButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/control_button_bg"
            android:contentDescription="@string/black_screen_desc"
            android:src="@drawable/ic_light" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>